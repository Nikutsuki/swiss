DATABASE_URL="postgresql://root:secretpassword@localhost:5432/utils_db?sslmode=disable"
NEXT_PUBLIC_ROOT_DOMAIN="localhost"
COOKIE_SECURE="true"
JWT_SECRET="dev-insecure-change-me"

# Browser-visible URLs (match `pnpm dev` ports: auth-portal 3000, monolith 3001, monolith-drop 3002, monolith-stream 3003).
# With --experimental-https + local certs, you may use https://auth.swiss.local:3000 etc. instead.
NEXT_PUBLIC_AUTH_URL="https://localhost:3000"
NEXT_PUBLIC_MONOLITH_URL="https://localhost:3001"
NEXT_PUBLIC_MONOLITH_DROP_URL="https://localhost:3002"
NEXT_PUBLIC_MONOLITH_STREAM_URL="https://localhost:3003"

# Server-side HTTP origins for API rewrites and server components (plain HTTP).
AUTH_API_ORIGIN=http://localhost:8080
MONOLITH_API_ORIGIN=http://localhost:8081
# Used by monolith-drop Next.js API routes (server-side). Start the API: task monolith-drop-api:dev
MONOLITH_DROP_API_ORIGIN=http://localhost:8082
# Used by monolith-stream Next.js rewrites (server-side). Start the API: task monolith-stream-api:dev
MONOLITH_STREAM_API_ORIGIN=http://localhost:8084

# Optional bind addresses for `go run` (defaults match ports above if unset).
AUTH_HTTP_ADDR=:8080
MONOLITH_HTTP_ADDR=:8081
MONOLITH_DROP_HTTP_ADDR=:8082
MONOLITH_STREAM_HTTP_ADDR=:8084
# Optional TLS (required for wss:// from an HTTPS Next dev server). Same cert pattern as signaling-api.
# MONOLITH_STREAM_TLS_CERT_FILE=/path/to/cert.pem
# MONOLITH_STREAM_TLS_KEY_FILE=/path/to/key.pem
# Comma-separated browser Origins for WebSocket upgrade (must match the page origin exactly, e.g. https://localhost:3003).
MONOLITH_STREAM_CORS_ORIGINS=https://localhost:3003
# Max signaling peers per room (WebRTC + chat use same session id). Default 16 in code if unset or invalid.
MONOLITH_STREAM_MAX_PEERS_PER_SESSION=16
# Optional HMAC secret for chat WS tokens from Next; if unset, monolith-stream-api falls back to JWT_SECRET.
# MONOLITH_STREAM_CHAT_HMAC_SECRET=
# Comma-separated origins allowed to call monolith-drop-api with credentials (browser CORS). Example:
# MONOLITH_DROP_CORS_ORIGINS=https://localhost:3002
MONOLITH_DROP_CORS_ORIGINS=

# WebRTC signaling (Go). Browser WebSocket URL must match page scheme (wss on HTTPS pages).
NEXT_PUBLIC_SIGNALING_WS_URL=ws://127.0.0.1:8083/ws
# Monolith Stream P2P signaling. Path is /v1/stream/ws. Use wss when the app is HTTPS (set MONOLITH_STREAM_TLS_*).
NEXT_PUBLIC_MONOLITH_STREAM_WS_URL=wss://localhost:8084/v1/stream/ws
# Optional JSON array of RTCIceServer objects (STUN/TURN) for monolith-drop; merged with default STUN.
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
SIGNALING_HTTP_ADDR=:8083
# Comma-separated allowed browser Origins for the WebSocket (empty = any, dev only). Example:
# SIGNALING_ALLOWED_ORIGINS=https://localhost:3002,https://localhost:3001
SIGNALING_ALLOWED_ORIGINS=
