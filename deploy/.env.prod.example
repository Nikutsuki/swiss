# --- Core domain ---
ROOT_DOMAIN=example.com

# --- Database ---
POSTGRES_USER=swiss
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=utils_db
DATABASE_URL=postgresql://swiss:replace_with_strong_password@postgres:5432/utils_db?sslmode=disable

# --- Auth/cookie ---
NEXT_PUBLIC_ROOT_DOMAIN=example.com
COOKIE_SECURE=true
JWT_SECRET=replace_with_long_random_secret

# --- Public app URLs ---
NEXT_PUBLIC_AUTH_URL=https://auth.example.com
NEXT_PUBLIC_MONOLITH_URL=https://monolith.example.com
NEXT_PUBLIC_MONOLITH_DROP_URL=https://drop.example.com
NEXT_PUBLIC_MONOLITH_STREAM_URL=https://stream.example.com

# --- Internal service origins (used by Next rewrites) ---
AUTH_API_ORIGIN=http://auth-api:8080
MONOLITH_API_ORIGIN=http://monolith-api:8081
MONOLITH_DROP_API_ORIGIN=http://monolith-drop-api:8082
MONOLITH_STREAM_API_ORIGIN=http://monolith-stream-api:8084

# --- Public WebSocket endpoints ---
NEXT_PUBLIC_SIGNALING_WS_URL=wss://signal.example.com/ws
NEXT_PUBLIC_MONOLITH_STREAM_WS_URL=wss://stream-api.example.com/v1/stream/ws
NEXT_PUBLIC_MONOLITH_STREAM_SIGNALING_HOST=stream-api.example.com

# --- CORS/Origin constraints ---
SIGNALING_ALLOWED_ORIGINS=https://drop.example.com,https://stream.example.com
MONOLITH_DROP_CORS_ORIGINS=https://drop.example.com
MONOLITH_STREAM_CORS_ORIGINS=https://stream.example.com

# --- Reverse proxy cert mount source ---
SSL_CERTS_DIR=/root/nikutsuki/ssl
